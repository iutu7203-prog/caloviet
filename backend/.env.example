# ── Bảo mật ──────────────────────────────────────────────
# Đổi thành chuỗi ngẫu nhiên mạnh trước khi deploy
SECRET_KEY=thay-bang-chuoi-bi-mat-ngau-nhien-it-nhat-32-ky-tu

# ── Database ──────────────────────────────────────────────
# Railway tự cấp khi thêm Postgres. Để trống = dùng SQLite local
DATABASE_URL=

# ── CORS ─────────────────────────────────────────────────
# Domain frontend, phân tách bằng dấu phẩy. Để * khi dev
CORS_ORIGINS=*

# ── Email (Gmail SMTP) ───────────────────────────────────
# Để trống = dev mode (mã OTP hiển thị trực tiếp, không gửi mail)
# Cách lấy App Password Gmail:
#   1. myaccount.google.com → Bảo mật → Xác minh 2 bước (bật)
#   2. Mật khẩu ứng dụng → Chọn Mail → Tạo → Copy 16 ký tự
SMTP_EMAIL=
SMTP_PASSWORD=

# ── App info ─────────────────────────────────────────────
APP_NAME=CaloViet
APP_URL=http://localhost:5173
